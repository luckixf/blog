# Astro Doge ships with built-in Vercel API routes under /api.
# If you only use the static blog, you can ignore this file entirely.

# Required for any built-in API feature
SITE_URL=https://your-domain.com
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Repository mapping
# Use separate repos, or only set GITHUB_REPO as a shared fallback.
COMMENTS_REPO=yourname/your-comments-repo
LIKES_REPO=yourname/your-likes-repo
CONTENT_REPO=yourname/your-blog-repo
GITHUB_REPO=yourname/your-shared-repo
CONTENT_BRANCH=main
THOUGHTS_CONTENT_DIR=src/content/thoughts
SITE_TIMEZONE=Asia/Shanghai

# Comments / messages owner verification
OWNER_NAME=Your Name
OWNER_EMAIL=you@example.com
OWNER_TOKEN=replace-this-with-a-random-secret

# Optional public hints for smoother owner verification in the browser.
# PUBLIC_OWNER_EMAIL is optional if you do not want to expose your email.
PUBLIC_OWNER_NAME=Your Name
PUBLIC_OWNER_EMAIL=you@example.com

# /thoughts/new online publishing
THOUGHT_API_TOKEN=replace-this-with-a-random-secret
