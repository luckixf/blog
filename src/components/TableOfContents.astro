---

---

<!-- 桌面端目录侧边栏 - 右侧，仅在宽屏显示 -->
<aside
  id="toc-sidebar"
  class="toc-sidebar fixed right-4 z-40 hidden xl:right-8 2xl:right-12"
  aria-label="文章目录"
>
  <!-- 目录头部 -->
  <div class="toc-header mb-2 flex items-center gap-2">
    <svg
      class="menu-icon h-[15px] w-[15px] text-stone-400 transition-colors duration-200 dark:text-stone-600"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="15" y2="12"></line>
      <line x1="3" y1="18" x2="9" y2="18"></line>
    </svg>
    <span
      class="toc-title text-xs font-medium text-stone-400 opacity-0 transition-opacity duration-200 dark:text-stone-500"
      >目录</span
    >
  </div>

  <!-- 目录内容 -->
  <nav id="toc-nav" class="toc-nav">
    <!-- 进度条 -->
    <div
      class="toc-progress-track absolute top-0 left-0 h-full w-[2px] rounded-full bg-stone-200/60 dark:bg-stone-800/60"
    >
      <div
        id="toc-progress-bar"
        class="toc-progress-bar w-full rounded-full bg-stone-400 transition-all duration-150 ease-out dark:bg-stone-500"
        style="height: 0%"
      >
      </div>
    </div>
    <ul class="toc-list space-y-1 pl-3">
      <!-- 动态生成 -->
    </ul>
  </nav>
</aside>

<!-- 移动端浮动目录按钮（xl 以下可见） -->
<button
  type="button"
  id="toc-mobile-toggle"
  class="toc-mobile-btn fixed right-4 bottom-10 z-50 hidden items-center justify-center sm:bottom-32 xl:hidden"
  aria-label="打开目录"
>
  <svg
    class="h-5 w-5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <line x1="3" y1="6" x2="21" y2="6"></line>
    <line x1="3" y1="12" x2="15" y2="12"></line>
    <line x1="3" y1="18" x2="9" y2="18"></line>
  </svg>
</button>

<!-- 移动端目录抽屉 -->
<div
  id="toc-mobile-drawer"
  class="fixed inset-0 z-[100] hidden xl:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="文章目录"
>
  <!-- 遮罩 -->
  <div
    class="toc-mobile-backdrop absolute inset-0 bg-black/50 opacity-0 backdrop-blur-sm transition-opacity duration-300"
  >
  </div>

  <!-- 抽屉内容 -->
  <div
    class="toc-mobile-content absolute right-0 bottom-0 left-0 translate-y-full transform rounded-t-2xl bg-white transition-transform duration-300 ease-out dark:bg-stone-900"
  >
    <!-- 拖动指示条 -->
    <div class="flex justify-center py-2">
      <div class="h-1 w-10 rounded-full bg-stone-300 dark:bg-stone-600"></div>
    </div>

    <!-- 抽屉头部 -->
    <div
      class="flex items-center justify-between border-b border-stone-200 px-5 pb-3 dark:border-stone-700"
    >
      <div class="flex items-center gap-3">
        <h3 class="text-base font-semibold text-stone-900 dark:text-stone-100">
          目录
        </h3>
        <span
          id="toc-mobile-heading-count"
          class="rounded-full bg-stone-100 px-2 py-0.5 text-xs text-stone-600 dark:bg-stone-800 dark:text-stone-400"
        >
          0 节
        </span>
      </div>
      <button
        type="button"
        id="toc-mobile-close"
        class="flex h-8 w-8 items-center justify-center rounded-full text-stone-500 transition-colors hover:bg-stone-100 dark:text-stone-400 dark:hover:bg-stone-800"
        aria-label="关闭目录"
      >
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- 目录列表 -->
    <nav
      id="toc-mobile-nav"
      class="max-h-[60vh] overflow-y-auto overscroll-contain px-4 py-3"
    >
      <ul class="toc-mobile-list space-y-1">
        <!-- 动态生成 -->
      </ul>
    </nav>

    <!-- 底部回到顶部按钮 -->
    <div class="border-t border-stone-200 px-5 py-4 dark:border-stone-700">
      <button
        type="button"
        id="toc-scroll-top"
        class="flex w-full items-center justify-center gap-2 rounded-lg border border-stone-200 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-stone-50 dark:border-stone-700 dark:text-stone-400 dark:hover:bg-stone-800"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 19V5M5 12l7-7 7 7"></path>
        </svg>
        回到顶部
      </button>
    </div>
  </div>
</div>

<script>
  function setupTableOfContents() {
    const sidebar = document.getElementById('toc-sidebar')
    const tocNav = document.getElementById('toc-nav')
    const menuIcon = sidebar?.querySelector('.menu-icon')
    const tocTitle = sidebar?.querySelector('.toc-title')
    const progressBar = document.getElementById('toc-progress-bar')
    const article = document.querySelector('article.post-content')

    const mobileToggle = document.getElementById('toc-mobile-toggle')
    const mobileDrawer = document.getElementById('toc-mobile-drawer')
    const mobileClose = document.getElementById('toc-mobile-close')
    const mobileNav = document.getElementById('toc-mobile-nav')
    const mobileHeadingCount = document.getElementById(
      'toc-mobile-heading-count',
    )

    const mobileBackdrop = mobileDrawer?.querySelector('.toc-mobile-backdrop')
    const mobileContent = mobileDrawer?.querySelector('.toc-mobile-content')
    const scrollTopBtn = document.getElementById('toc-scroll-top')

    if (!article) {
      if (sidebar) sidebar.style.display = 'none'
      if (mobileToggle) mobileToggle.style.display = 'none'
      return
    }

    const headings = article.querySelectorAll('h1, h2, h3, h4, h5, h6')
    if (headings.length === 0) {
      if (sidebar) sidebar.style.display = 'none'
      if (mobileToggle) mobileToggle.style.display = 'none'
      return
    }

    if (mobileToggle && window.innerWidth < 1280) {
      mobileToggle.style.display = 'flex'
    }

    if (mobileHeadingCount) {
      mobileHeadingCount.textContent = `${headings.length} 节`
    }

    const updateTocPosition = () => {
      if (!sidebar) return
      const width = window.innerWidth

      if (width < 1280) {
        sidebar.style.display = 'none'
        return
      }

      const container = article.closest('.mx-auto')
      if (!container) return

      const containerRect = container.getBoundingClientRect()
      const rightSpace = width - containerRect.right

      if (rightSpace > 160) {
        sidebar.style.display = 'block'
        sidebar.style.left = `${containerRect.right + 32}px`
        sidebar.style.right = 'auto'
        sidebar.style.maxWidth = `${Math.min(rightSpace - 48, 200)}px`
      } else {
        sidebar.style.display = 'none'
        return
      }

      sidebar.style.top = '5.5rem'
    }

    updateTocPosition()
    window.addEventListener('resize', updateTocPosition)

    let minLevel = 6
    headings.forEach((heading) => {
      const level = parseInt(heading.tagName.charAt(1))
      if (level < minLevel) minLevel = level
    })

    const generateTOC = (container: Element, isMobile = false) => {
      const listClass = isMobile ? '.toc-mobile-list' : '.toc-list'
      const list = container.querySelector(listClass)
      if (!list) return

      list.innerHTML = ''

      headings.forEach((heading, index) => {
        const level = parseInt(heading.tagName.charAt(1))
        const text = heading.textContent?.replace('#', '').trim() || ''
        const id = heading.id || `heading-${index}`

        if (!heading.id) {
          heading.id = id
        }

        const li = document.createElement('li')
        li.className = isMobile
          ? `toc-mobile-item toc-level-${level}`
          : `toc-item toc-level-${level}`

        const a = document.createElement('a')
        a.href = `#${id}`
        a.className = isMobile
          ? 'toc-mobile-link block rounded-lg px-3 py-2 text-sm text-stone-600 transition-colors hover:bg-stone-100 dark:text-stone-400 dark:hover:bg-stone-800'
          : 'toc-link block truncate py-[3px] text-[11px] leading-snug text-stone-400 transition-all duration-200 hover:text-stone-700 dark:text-stone-600 dark:hover:text-stone-300'
        a.textContent = text
        a.dataset.headingId = id
        a.title = text

        const relativeLevel = level - minLevel
        const indent = relativeLevel * (isMobile ? 12 : 10)
        a.style.paddingLeft = isMobile ? `${12 + indent}px` : `${indent}px`

        li.appendChild(a)
        list.appendChild(li)
      })
    }

    if (tocNav) generateTOC(tocNav)
    if (mobileNav) generateTOC(mobileNav, true)

    let activeLink: Element | null = null
    let activeMobileLink: Element | null = null

    const updateActiveHeading = () => {
      let currentHeading: Element | null = null
      let currentIndex = -1

      headings.forEach((heading, index) => {
        const rect = heading.getBoundingClientRect()
        if (rect.top <= 150) {
          currentHeading = heading
          currentIndex = index
        }
      })

      if (progressBar) {
        if (currentIndex >= 0) {
          const progress = ((currentIndex + 1) / headings.length) * 100
          progressBar.style.height = `${Math.min(progress, 100)}%`
        } else {
          progressBar.style.height = '0%'
        }
      }

      if (currentHeading) {
        const id = (currentHeading as HTMLElement).id

        if (tocNav) {
          const newActiveLink = tocNav.querySelector(
            `a[data-heading-id="${id}"]`,
          )
          if (newActiveLink && newActiveLink !== activeLink) {
            if (activeLink) {
              activeLink.classList.remove(
                'toc-active',
                'text-stone-800',
                'dark:text-stone-200',
                'font-medium',
              )
              activeLink.classList.add('text-stone-400', 'dark:text-stone-600')
            }
            newActiveLink.classList.add(
              'toc-active',
              'text-stone-800',
              'dark:text-stone-200',
              'font-medium',
            )
            newActiveLink.classList.remove(
              'text-stone-400',
              'dark:text-stone-600',
            )
            activeLink = newActiveLink

            const navEl = tocNav as HTMLElement
            const linkEl = newActiveLink as HTMLElement
            const navRect = navEl.getBoundingClientRect()
            const linkRect = linkEl.getBoundingClientRect()

            if (
              linkRect.top < navRect.top + 20 ||
              linkRect.bottom > navRect.bottom - 20
            ) {
              linkEl.scrollIntoView({
                block: 'center',
                behavior: 'smooth',
              })
            }
          }
        }

        if (mobileNav) {
          const newMobileLink = mobileNav.querySelector(
            `a[data-heading-id="${id}"]`,
          )
          if (newMobileLink && newMobileLink !== activeMobileLink) {
            if (activeMobileLink) {
              activeMobileLink.classList.remove('toc-mobile-active')
            }
            newMobileLink.classList.add('toc-mobile-active')
            activeMobileLink = newMobileLink
          }
        }
      }
    }

    let ticking = false
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateActiveHeading()
            ticking = false
          })
          ticking = true
        }
      },
      { passive: true },
    )

    updateActiveHeading()

    const scrollToHeading = (headingId: string) => {
      const heading = document.getElementById(headingId)
      if (heading) {
        const headerOffset = 80
        const elementPosition = heading.getBoundingClientRect().top
        const offsetPosition =
          elementPosition + window.pageYOffset - headerOffset

        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth',
        })
      }
    }

    const handleDesktopTOCClick = (e: Event) => {
      const target = e.target as HTMLElement
      if (target.classList.contains('toc-link')) {
        e.preventDefault()
        e.stopPropagation()
        const id = target.dataset.headingId
        if (id) {
          scrollToHeading(id)
        }
      }
    }

    let pendingScrollId: string | null = null

    const handleMobileTOCClick = (e: Event) => {
      const target = e.target as HTMLElement
      if (target.classList.contains('toc-mobile-link')) {
        e.preventDefault()
        e.stopPropagation()
        const id = target.dataset.headingId
        if (id) {
          pendingScrollId = id
          closeMobileDrawer()
        }
      }
    }

    if (tocNav) tocNav.addEventListener('click', handleDesktopTOCClick)
    if (mobileNav) mobileNav.addEventListener('click', handleMobileTOCClick)

    let pendingScrollTop = false

    if (scrollTopBtn) {
      scrollTopBtn.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        pendingScrollTop = true
        closeMobileDrawer()
      })
    }

    const openMobileDrawer = () => {
      if (!mobileDrawer) return
      mobileDrawer.classList.remove('hidden')
      document.documentElement.style.overflow = 'hidden'
      document.body.style.overflow = 'hidden'
      requestAnimationFrame(() => {
        mobileBackdrop?.classList.add('opacity-100')
        mobileBackdrop?.classList.remove('opacity-0')
        mobileContent?.classList.remove('translate-y-full')
        mobileContent?.classList.add('translate-y-0')
      })
    }

    const closeMobileDrawer = () => {
      if (!mobileDrawer) return
      mobileBackdrop?.classList.remove('opacity-100')
      mobileBackdrop?.classList.add('opacity-0')
      mobileContent?.classList.add('translate-y-full')
      mobileContent?.classList.remove('translate-y-0')

      setTimeout(() => {
        mobileDrawer.classList.add('hidden')
        document.documentElement.style.overflow = ''
        document.body.style.overflow = ''

        if (pendingScrollId) {
          const id = pendingScrollId
          pendingScrollId = null
          requestAnimationFrame(() => {
            scrollToHeading(id)
          })
        }
        if (pendingScrollTop) {
          pendingScrollTop = false
          requestAnimationFrame(() => {
            window.scrollTo({ top: 0, behavior: 'smooth' })
          })
        }
      }, 300)
    }

    if (mobileToggle) {
      mobileToggle.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        openMobileDrawer()
      })
    }
    if (mobileClose) {
      mobileClose.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        closeMobileDrawer()
      })
    }
    if (mobileBackdrop) {
      mobileBackdrop.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        closeMobileDrawer()
      })
    }

    if (sidebar && window.innerWidth >= 1280) {
      sidebar.classList.add('toc-visible')

      sidebar.addEventListener('mouseenter', () => {
        sidebar.classList.add('toc-hovered')
        menuIcon?.classList.add('menu-active')
        tocTitle?.classList.add('opacity-100')
        tocTitle?.classList.remove('opacity-0')
      })

      sidebar.addEventListener('mouseleave', () => {
        sidebar.classList.remove('toc-hovered')
        menuIcon?.classList.remove('menu-active')
        tocTitle?.classList.remove('opacity-100')
        tocTitle?.classList.add('opacity-0')
      })
    }

    const handleResize = () => {
      const width = window.innerWidth
      if (width >= 1280) {
        closeMobileDrawer()
        if (mobileToggle) {
          mobileToggle.style.display = 'none'
        }
      } else {
        if (mobileToggle) {
          mobileToggle.style.display = 'flex'
        }
      }
      updateTocPosition()
    }

    window.addEventListener('resize', handleResize)
  }

  document.addEventListener('DOMContentLoaded', setupTableOfContents)
  document.addEventListener('astro:after-swap', setupTableOfContents)

  if (document.readyState === 'complete') {
    setupTableOfContents()
  }
</script>

<style>
  .toc-sidebar {
    max-width: 200px;
    opacity: 1;
  }

  .toc-nav {
    position: relative;
    max-height: calc(100vh - 10rem);
    overflow-y: auto;
    overflow-x: hidden;
    opacity: 0.45;
    transition: opacity 0.3s ease;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .toc-nav::-webkit-scrollbar {
    display: none;
  }

  .toc-sidebar.toc-visible .toc-nav {
    opacity: 0.45;
  }

  .toc-sidebar.toc-hovered .toc-nav {
    opacity: 1;
  }

  .toc-progress-track {
    position: absolute;
    top: 0;
    left: 0;
  }

  .menu-icon {
    transition: color 0.2s ease;
  }

  .menu-icon.menu-active {
    color: rgb(87 83 78);
  }

  :global(.dark) .menu-icon.menu-active {
    color: rgb(168 162 158);
  }

  .toc-link {
    position: relative;
  }

  .toc-link.toc-active {
    font-weight: 500;
  }

  .toc-mobile-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    color: rgb(120 113 108);
  }

  @media (min-width: 640px) {
    .toc-mobile-btn {
      width: 48px;
      height: 48px;
    }
  }

  :global(.dark) .toc-mobile-btn {
    background: rgb(28 25 23);
    color: rgb(168 162 158);
  }

  .toc-mobile-btn:hover {
    background: rgb(250 250 249);
    border-color: rgb(214 211 209);
  }

  :global(.dark) .toc-mobile-btn:hover {
    background: rgb(41 37 36);
    border-color: rgb(87 83 78);
  }

  .toc-mobile-link.toc-mobile-active {
    background: rgb(245 245 244);
    color: rgb(28 25 23);
    font-weight: 500;
  }

  :global(.dark) .toc-mobile-link.toc-mobile-active {
    background: rgb(41 37 36);
    color: rgb(250 250 249);
  }
</style>
