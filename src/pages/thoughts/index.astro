---
import Container from '@components/Container.astro'
import ThoughtItem from '@components/ThoughtItem.astro'
import { THOUGHTS } from '@consts'
import PageLayout from '@layouts/PageLayout.astro'
import {
  THOUGHTS_PAGE_SIZE,
  getSortedThoughts,
  getThoughtCatalog,
  getThoughtStats,
  getThoughtChunks,
  renderThoughtEntries,
} from '@lib/thoughts'

const collection = await getSortedThoughts()
const chunks = getThoughtChunks(collection)
const thoughts = await renderThoughtEntries(chunks[0] ?? [], collection)
const catalog = getThoughtCatalog(collection)
const stats = getThoughtStats(collection)
const totalPages = chunks.length
---

<PageLayout title={THOUGHTS.TITLE} description={THOUGHTS.DESCRIPTION}>
  <Container>
    <div
      class="thought-page space-y-8"
      data-page-size={THOUGHTS_PAGE_SIZE}
      data-total-items={collection.length}
      data-total-pages={totalPages}
      data-loaded-page="1"
    >
      <section class="thought-hero animate">
        <div class="thought-title-row">
          <h1 class="text-3xl font-semibold text-stone-900 dark:text-stone-100">
            碎碎念
          </h1>
          <a class="thought-rss-link" href="/rss.xml" target="_blank" rel="noopener noreferrer">
            RSS
          </a>
        </div>
        <p class="thought-description">
          {
            `一些不成文的瞬间，记录生活、心情与灵感。共 ${stats.total} 条内容，月均 ${stats.monthlyAverage} 条，累计 ${stats.totalWords.toLocaleString('zh-CN')} 字。`
          }
        </p>
      </section>

      {
        catalog.length > 0 && (
          <nav class="thought-toc animate" aria-label="碎碎念目录">
            <div class="thought-toc-title">目录</div>
            <ol class="thought-toc-list">
              {catalog.map((item) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    class="thought-toc-link"
                    data-toc-link
                    data-thought-id={item.id}
                    data-page={item.chunk}
                    title={`#${item.id} ${item.label}`}
                  >
                    <span class="thought-toc-number">#{item.id}</span>
                    <span class="thought-toc-text">{item.label}</span>
                    <span class="thought-toc-date">{item.shortDate}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      <section class="thought-main animate">
        {
          thoughts.length > 0 ? (
            <>
              <ul class="thought-feed" data-thought-feed>
                {thoughts.map((entry) => (
                  <ThoughtItem entry={entry} />
                ))}
              </ul>
              {totalPages > 1 && (
                <div class="thought-load-wrap">
                  <button
                    type="button"
                    class="thought-load-more"
                    data-load-more
                    data-next-page="2"
                  >
                    <span data-load-text>
                      继续加载 {Math.min(THOUGHTS_PAGE_SIZE, collection.length - THOUGHTS_PAGE_SIZE)} 条
                    </span>
                  </button>
                  <p class="thought-load-hint">
                    首屏只加载最近 {Math.min(THOUGHTS_PAGE_SIZE, collection.length)} 条，图片随内容进入页面后再请求。
                  </p>
                </div>
              )}
            </>
          ) : (
            <div class="thought-empty">还没有碎碎念，快来记录第一条吧。</div>
          )
        }
      </section>
    </div>
  </Container>

  {
    catalog.length > 0 && (
      <>
        <button
          type="button"
          class="thought-mobile-toc-button"
          data-mobile-toc-open
          aria-label="打开碎碎念目录"
        >
          目录
        </button>
        <div class="thought-mobile-toc-mask" data-mobile-toc-mask hidden></div>
        <aside class="thought-mobile-toc" data-mobile-toc aria-hidden="true">
          <div class="thought-mobile-toc-handle" aria-hidden="true"></div>
          <div class="thought-mobile-toc-head">
            <span>碎碎念目录</span>
            <button type="button" data-mobile-toc-close aria-label="关闭碎碎念目录">
              关闭
            </button>
          </div>
          <ol class="thought-mobile-toc-list">
            {catalog.map((item) => (
              <li>
                <a
                  href={`#${item.id}`}
                  class="thought-mobile-toc-link"
                  data-toc-link
                  data-thought-id={item.id}
                  data-page={item.chunk}
                  title={`#${item.id} ${item.label}`}
                >
                  <span class="thought-toc-number">#{item.id}</span>
                  <span class="thought-toc-text">{item.label}</span>
                  <span class="thought-toc-date">{item.shortDate}</span>
                </a>
              </li>
            ))}
          </ol>
        </aside>
      </>
    )
  }

  <div
    id="copy-toast"
    class="pointer-events-none fixed bottom-8 left-1/2 z-50 -translate-x-1/2 transform opacity-0 transition-all duration-300"
  >
    <div
      class="rounded-lg bg-stone-800/90 px-4 py-2 text-sm text-white shadow-lg dark:bg-stone-200 dark:text-stone-800"
    >
      <span id="toast-message">✓ 链接已复制</span>
    </div>
  </div>
</PageLayout>

<script>
  import { setupTimeAgo } from '@lib/timeago-client'
  import { formatLikeCount, getLikes, sendLike } from '@lib/likes-client'

  let toastTimer: ReturnType<typeof setTimeout> | null = null
  let loadingPage: Promise<void> | null = null

  function showToast(message: string) {
    const toast = document.getElementById('copy-toast')
    const msgEl = document.getElementById('toast-message')
    if (toast && msgEl) {
      msgEl.textContent = message
      if (toastTimer) clearTimeout(toastTimer)
      toast.classList.remove('opacity-0')
      toast.classList.add('opacity-100')
      toastTimer = setTimeout(() => {
        toast.classList.remove('opacity-100')
        toast.classList.add('opacity-0')
      }, 2000)
    }
  }

  const bubbleTimers = new Map<string, ReturnType<typeof setTimeout>>()

  type BubbleVariant = 'liked' | 'thanks' | 'error'

  const BUBBLE_STYLES: Record<BubbleVariant, { bg: string; text: string }> = {
    liked: {
      bg: 'bg-stone-100 dark:bg-stone-800',
      text: 'text-stone-500 dark:text-stone-400',
    },
    thanks: {
      bg: 'bg-rose-50 dark:bg-rose-950/60',
      text: 'text-rose-500 dark:text-rose-400',
    },
    error: {
      bg: 'bg-stone-100 dark:bg-stone-800',
      text: 'text-stone-400 dark:text-stone-500',
    },
  }

  function showBubble(
    btn: HTMLElement,
    message: string,
    variant: BubbleVariant,
    duration = 1500,
  ) {
    const wrap = btn.closest('.thought-like-wrap')
    if (!wrap) return
    const bubble = wrap.querySelector('.thought-bubble') as HTMLElement | null
    if (!bubble) return

    const id = btn.dataset.thoughtId || ''
    const oldTimer = bubbleTimers.get(id)
    if (oldTimer) {
      clearTimeout(oldTimer)
      bubbleTimers.delete(id)
    }

    bubble.className = [
      'thought-bubble pointer-events-none absolute right-0 bottom-full mb-1.5',
      'whitespace-nowrap rounded-md px-2 py-1 text-[11px] font-medium leading-none',
      BUBBLE_STYLES[variant].bg,
      BUBBLE_STYLES[variant].text,
      'bubble-enter',
    ].join(' ')
    bubble.textContent = message

    requestAnimationFrame(() => {
      bubble.classList.add('bubble-visible')
    })

    const timer = setTimeout(() => {
      bubble.classList.remove('bubble-visible')
      bubble.classList.add('bubble-leave')
      bubble.addEventListener(
        'transitionend',
        () => {
          bubble.className =
            'thought-bubble pointer-events-none absolute right-0 bottom-full mb-1.5 whitespace-nowrap rounded-md px-2 py-1 text-[11px] font-medium leading-none opacity-0'
          bubble.textContent = ''
        },
        { once: true },
      )
      bubbleTimers.delete(id)
    }, duration)

    bubbleTimers.set(id, timer)
  }

  async function copyAndScrollToThought(thoughtId: string) {
    const url = `${window.location.origin}${window.location.pathname}#${thoughtId}`

    try {
      await navigator.clipboard.writeText(url)
      showToast('✓ 链接已复制')
    } catch {
      // ignore copy failure
    }

    history.pushState(null, '', `#${thoughtId}`)

    const element = document.getElementById(`${thoughtId}`)
    if (element) {
      element.scrollIntoView({ behavior: 'smooth', block: 'start' })
      highlightElement(element)
    }
  }

  function setupAnchorLinks(root: ParentNode = document) {
    root.querySelectorAll('.thought-anchor').forEach((anchor) => {
      const el = anchor as HTMLElement
      if (el.dataset.anchorBound === 'true') return
      el.dataset.anchorBound = 'true'

      el.addEventListener('click', async (e) => {
        e.preventDefault()
        const thoughtId = el.dataset.thoughtId
        if (!thoughtId) return
        await copyAndScrollToThought(thoughtId)
      })
    })
  }

  function highlightElement(element: HTMLElement) {
    element.classList.remove('highlight-thought')
    element.getBoundingClientRect()
    element.classList.add('highlight-thought')
    setTimeout(() => {
      element.classList.remove('highlight-thought')
    }, 2000)
  }

  function highlightAnchor() {
    const hash = window.location.hash.slice(1)
    if (!hash) return

    const element = document.getElementById(hash)
    if (element) highlightElement(element)
  }

  function updateLikeButton(btn: HTMLElement, total: number, userToday: number) {
    const countEl = btn.querySelector('.thought-like-count') as HTMLElement
    const emptyHeart = btn.querySelector('.thought-heart-empty') as HTMLElement
    const filledHeart = btn.querySelector('.thought-heart-filled') as HTMLElement

    if (!countEl || !emptyHeart || !filledHeart) return

    countEl.textContent = formatLikeCount(total)

    if (userToday > 0) {
      btn.dataset.liked = 'true'
      emptyHeart.style.display = 'none'
      filledHeart.style.display = 'inline-flex'
      btn.classList.add('text-rose-500', 'dark:text-rose-400')
      btn.classList.remove(
        'text-stone-400',
        'dark:text-stone-600',
        'hover:text-rose-500',
        'dark:hover:text-rose-400',
      )
    } else {
      btn.dataset.liked = 'false'
      emptyHeart.style.display = 'inline-flex'
      filledHeart.style.display = 'none'
      btn.classList.remove('text-rose-500', 'dark:text-rose-400')
      btn.classList.add(
        'text-stone-400',
        'dark:text-stone-600',
        'hover:text-rose-500',
        'dark:hover:text-rose-400',
      )
    }
  }

  function animateHeart(btn: HTMLElement) {
    const filledHeart = btn.querySelector('.thought-heart-filled') as HTMLElement
    if (!filledHeart) return

    const svg = filledHeart.querySelector('svg')
    if (!svg) return

    svg.style.animation = 'none'
    svg.getBoundingClientRect()
    svg.style.animation =
      'thought-heart-pop 0.45s cubic-bezier(0.17,0.89,0.32,1.49)'
    svg.addEventListener(
      'animationend',
      () => {
        svg.style.animation = ''
      },
      { once: true },
    )
  }

  async function loadThoughtLikes(root: ParentNode = document) {
    const buttons = root.querySelectorAll(
      '.thought-like-btn',
    ) as NodeListOf<HTMLElement>
    if (buttons.length === 0) return

    const ids: string[] = []
    buttons.forEach((btn) => {
      const id = btn.dataset.thoughtId
      if (id) ids.push(id)
    })

    try {
      const result = await getLikes(ids, 'thought')

      buttons.forEach((btn) => {
        const id = btn.dataset.thoughtId
        if (!id) return
        const key = `thought:${id}`
        const info = result[key]
        if (info) {
          updateLikeButton(btn, info.total, info.userToday)
        }
      })
    } catch {
      // ignore
    }
  }

  const likeInProgress = new Set<string>()

  function setupLikeButtons(root: ParentNode = document) {
    root.querySelectorAll('.thought-like-btn').forEach((btn) => {
      const button = btn as HTMLElement
      if (button.dataset.likeBound === 'true') return
      button.dataset.likeBound = 'true'

      button.addEventListener('click', async (e) => {
        e.preventDefault()
        e.stopPropagation()

        const thoughtId = button.dataset.thoughtId
        if (!thoughtId) return
        if (likeInProgress.has(thoughtId)) return
        likeInProgress.add(thoughtId)

        if (button.dataset.liked === 'true') {
          showBubble(button, '今日已点赞 ❤️', 'liked', 1400)
          likeInProgress.delete(thoughtId)
          return
        }

        const countEl = button.querySelector('.thought-like-count') as HTMLElement
        const currentCount = parseInt(countEl?.textContent || '0') || 0
        updateLikeButton(button, currentCount + 1, 1)
        animateHeart(button)
        showBubble(button, '点赞成功 ❤️', 'thanks', 1600)

        try {
          const result = await sendLike(thoughtId, 'thought')

          if (result.limited) {
            updateLikeButton(button, result.total, result.userToday)
            if (result.limitReason === 'daily_cap') {
              showBubble(button, '今日点赞已达上限', 'liked', 1600)
            } else {
              showBubble(button, '今日已点赞 ❤️', 'liked', 1400)
            }
          } else if (result.success) {
            updateLikeButton(button, result.total, result.userToday)
          }
        } catch (error) {
          updateLikeButton(button, currentCount, 0)
          showBubble(
            button,
            error instanceof Error ? error.message : '出错了，稍后再试',
            'error',
            1800,
          )
        } finally {
          likeInProgress.delete(thoughtId)
        }
      })
    })
  }

  function prepareThoughtMedia(root: ParentNode = document) {
    root.querySelectorAll<HTMLImageElement>('.thought-content img').forEach((img) => {
      img.loading = 'lazy'
      img.decoding = 'async'
      if (!img.sizes) img.sizes = '(max-width: 640px) 92vw, 720px'
    })
  }

  function syncLoadMoreButton() {
    const page = document.querySelector('.thought-page') as HTMLElement | null
    const button = document.querySelector('[data-load-more]') as HTMLButtonElement | null
    const text = document.querySelector('[data-load-text]') as HTMLElement | null
    if (!page || !button || !text) return

    const loadedPage = Number(page.dataset.loadedPage || '1')
    const totalPages = Number(page.dataset.totalPages || '1')
    const pageSize = Number(page.dataset.pageSize || '6')
    const totalItems = Number(page.dataset.totalItems || '0')
    const loadedItems = document.querySelectorAll('[data-thought-item]').length
    const remaining = Math.max(0, (totalItems || loadedItems) - loadedItems)

    if (loadedPage >= totalPages || remaining === 0) {
      button.hidden = true
      return
    }

    button.hidden = false
    button.dataset.nextPage = String(loadedPage + 1)
    text.textContent = `继续加载 ${Math.min(pageSize, remaining)} 条`
  }

  function initInsertedThoughts(root: ParentNode = document) {
    setupTimeAgo()
    setupAnchorLinks(root)
    setupLikeButtons(root)
    prepareThoughtMedia(root)
    loadThoughtLikes(root)
  }

  async function loadPage(pageNumber: number) {
    const page = document.querySelector('.thought-page') as HTMLElement | null
    const feed = document.querySelector('[data-thought-feed]')
    if (!page || !feed) return

    const loadedPage = Number(page.dataset.loadedPage || '1')
    const totalPages = Number(page.dataset.totalPages || '1')
    if (pageNumber <= loadedPage || pageNumber > totalPages) return

    if (loadingPage) {
      await loadingPage
      return loadPage(pageNumber)
    }

    const button = document.querySelector('[data-load-more]') as HTMLButtonElement | null
    if (button) {
      button.disabled = true
      button.classList.add('is-loading')
    }

    loadingPage = (async () => {
      for (let pageIndex = loadedPage + 1; pageIndex <= pageNumber; pageIndex++) {
        const response = await fetch(`/thoughts/chunks/${pageIndex}/`)
        if (!response.ok) throw new Error(`Failed to load thoughts chunk ${pageIndex}`)

        const html = await response.text()
        const template = document.createElement('template')
        template.innerHTML = html.trim()
        // Chunk routes may include wrapper nodes; only append thought cards.
        const items = Array.from(
          template.content.querySelectorAll('[data-thought-item]'),
        )
        const fragment = document.createDocumentFragment()
        items.forEach((item) => fragment.appendChild(item))
        initInsertedThoughts(fragment)
        feed.appendChild(fragment)
        page.dataset.loadedPage = String(pageIndex)
      }
    })()

    try {
      await loadingPage
    } catch {
      showToast('加载失败，请稍后再试')
    } finally {
      loadingPage = null
      if (button) {
        button.disabled = false
        button.classList.remove('is-loading')
      }
      syncLoadMoreButton()
    }
  }

  function setupLoadMore() {
    const button = document.querySelector('[data-load-more]') as HTMLButtonElement | null
    if (!button || button.dataset.loadBound === 'true') return
    button.dataset.loadBound = 'true'

    button.addEventListener('click', async () => {
      const nextPage = Number(button.dataset.nextPage || '2')
      await loadPage(nextPage)
    })
  }

  function closeMobileToc() {
    const panel = document.querySelector('[data-mobile-toc]') as HTMLElement | null
    const mask = document.querySelector('[data-mobile-toc-mask]') as HTMLElement | null
    if (!panel || !mask) return

    panel.classList.remove('is-open')
    panel.setAttribute('aria-hidden', 'true')
    mask.hidden = true
    document.documentElement.classList.remove('thought-toc-lock')
  }

  function setupMobileToc() {
    const open = document.querySelector('[data-mobile-toc-open]') as HTMLButtonElement | null
    const close = document.querySelector('[data-mobile-toc-close]') as HTMLButtonElement | null
    const panel = document.querySelector('[data-mobile-toc]') as HTMLElement | null
    const mask = document.querySelector('[data-mobile-toc-mask]') as HTMLElement | null
    if (!open || !close || !panel || !mask || open.dataset.tocBound === 'true') return
    open.dataset.tocBound = 'true'

    open.addEventListener('click', () => {
      mask.hidden = false
      panel.classList.add('is-open')
      panel.setAttribute('aria-hidden', 'false')
      document.documentElement.classList.add('thought-toc-lock')
    })

    close.addEventListener('click', closeMobileToc)
    mask.addEventListener('click', closeMobileToc)
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMobileToc()
    })
  }

  function setupTocLinks() {
    document.querySelectorAll('[data-toc-link]').forEach((link) => {
      const el = link as HTMLElement
      if (el.dataset.tocBound === 'true') return
      el.dataset.tocBound = 'true'

      el.addEventListener('click', async (event) => {
        event.preventDefault()
        const thoughtId = el.dataset.thoughtId
        const page = Number(el.dataset.page || '1')
        if (!thoughtId) return

        closeMobileToc()
        await loadPage(page)
        history.pushState(null, '', `#${thoughtId}`)
        const target = document.getElementById(thoughtId)
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' })
          highlightElement(target)
        }
      })
    })
  }

  async function loadInitialHash() {
    const thoughtId = window.location.hash.slice(1)
    if (!thoughtId) return

    const tocLink = document.querySelector(
      `[data-toc-link][data-thought-id="${CSS.escape(thoughtId)}"]`,
    ) as HTMLElement | null
    const page = Number(tocLink?.dataset.page || '1')
    await loadPage(page)
    highlightAnchor()
  }

  function init() {
    initInsertedThoughts()
    setupLoadMore()
    setupMobileToc()
    setupTocLinks()
    syncLoadMoreButton()
    loadInitialHash()
  }

  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:after-swap', init)

  if (document.readyState === 'complete') {
    init()
  }
</script>

<style is:global>
  .thought-hero {
    border: 1px solid rgb(var(--kawaii-primary-rgb) / 0.14);
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--kawaii-surface-soft) 58%, transparent);
    padding: 1.15rem 1.25rem;
    box-shadow: 0 16px 42px rgb(var(--kawaii-primary-rgb) / 0.08);
    backdrop-filter: blur(12px) saturate(1.06);
    -webkit-backdrop-filter: blur(12px) saturate(1.06);
  }

  .thought-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .thought-rss-link {
    border-radius: 999px;
    border: 1px solid rgb(var(--kawaii-primary-rgb) / 0.16);
    background: rgb(var(--kawaii-primary-rgb) / 0.08);
    padding: 0.24rem 0.65rem;
    color: var(--kawaii-primary);
    font-size: 0.72rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .thought-rss-link:hover {
    background: rgb(var(--kawaii-primary-rgb) / 0.14);
    transform: translateY(-1px);
  }

  .thought-description {
    margin-top: 0.85rem;
    max-width: 42rem;
    color: var(--kawaii-muted);
    font-size: 0.92rem;
    line-height: 1.9;
  }

  .thought-main {
    position: relative;
  }

  .thought-toc {
    display: none;
  }

  .thought-feed {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .thought-feed::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: 0.54rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      rgb(var(--kawaii-primary-rgb) / 0.28),
      transparent
    );
  }

  .thought-item {
    position: relative;
    padding-left: 1.6rem;
  }

  .thought-card {
    position: relative;
    border: 1px solid rgb(var(--kawaii-primary-rgb) / 0.16);
    border-radius: 1.1rem;
    background: color-mix(in srgb, var(--kawaii-surface-soft) 54%, transparent);
    padding: 0.85rem 1rem 0.95rem;
    box-shadow: 0 10px 28px rgb(var(--kawaii-primary-rgb) / 0.07);
    backdrop-filter: blur(10px) saturate(1.06);
    -webkit-backdrop-filter: blur(10px) saturate(1.06);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .thought-card:hover {
    transform: translateY(-1px);
    border-color: rgb(var(--kawaii-primary-rgb) / 0.28);
    background: color-mix(in srgb, var(--kawaii-surface-soft) 68%, transparent);
    box-shadow: 0 14px 32px rgb(var(--kawaii-primary-rgb) / 0.11);
  }

  .thought-pin {
    position: absolute;
    top: 1.05rem;
    left: -1.42rem;
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 999px;
    box-shadow:
      0 0 0 4px rgb(var(--kawaii-primary-rgb) / 0.1),
      0 8px 20px rgb(var(--kawaii-primary-rgb) / 0.18);
  }

  .thought-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.38rem 0.55rem;
    color: var(--kawaii-muted);
    font-size: 0.76rem;
    font-weight: 600;
    line-height: 1.6;
  }

  .thought-separator {
    color: rgb(var(--kawaii-primary-rgb) / 0.35);
  }

  .thought-actions {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

