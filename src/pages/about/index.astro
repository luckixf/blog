---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { ABOUT, PROJECTS, SITE, SOCIALS, TECH_STACK } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <div class="space-y-4">
      <h1
        class="animate text-3xl font-semibold text-stone-900 dark:text-stone-100"
      >
        Luckixf
      </h1>
      <p class="animate mb-8 text-stone-600 dark:text-stone-400">
        在学土木的苦逼大学生
      </p>
    </div>

    <div class="space-y-8 sm:space-y-10">
      <!-- 个人介绍 -->
      <section class="animate">
        <h2
          class="mb-3 flex items-center gap-2 text-base font-semibold text-stone-900 sm:mb-4 sm:text-lg dark:text-stone-100"
        >
          Profile
        </h2>
        <div
          class="space-y-4 text-sm text-stone-700 sm:text-base dark:text-stone-300"
        >
          <p>
            我只是一名普通的大学生，学的还是土木工程。暂时没有什么能力算是出众，也没有可以拿来介绍自己的资质。emmm……期待自己会慢慢变得厉害吧
          </p>
          <p class="text-xs leading-relaxed text-stone-500 sm:text-sm dark:text-stone-400">
            🏷️标签：二刺螈/阿宅/拯救世界，我的世界/碧蓝航线/第五人格，间歇性上进/时常摆烂/不想读书，自我孤立/社交恐惧/畏难畏危，讨好型人格/缺少主见/腼腼腆腆
          </p>
        </div>
      </section>

      <!-- 联系方式 -->
      <section class="animate">
        <h2
          class="mb-3 flex items-center gap-2 text-base font-semibold text-stone-900 sm:mb-4 sm:text-lg dark:text-stone-100"
        >
          Contact
        </h2>
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
          {
            SOCIALS.map((social) => (
              <Link
                href={social.HREF}
                external
                class="text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
              >
                {social.NAME}
              </Link>
            ))
          }
          <Link
            href={`mailto:${SITE.EMAIL}`}
            class="text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
          >
            {SITE.EMAIL}
          </Link>
        </div>
      </section>

      <!-- 项目 -->
      <section class="animate">
        <h2
          class="mb-3 flex items-center gap-2 text-base font-semibold text-stone-900 sm:mb-4 sm:text-lg dark:text-stone-100"
        >
          Projects
        </h2>
        <div class="space-y-6">
          {
            PROJECTS.map((group) => (
              <div class="space-y-2">
                <h3 class="text-xs font-medium uppercase tracking-wider text-stone-500 dark:text-stone-400">
                  {group.category}
                </h3>
                <ul class="space-y-2">
                  {group.items.map((project) => (
                    <li class="text-sm text-stone-700 dark:text-stone-300">
                      <div class="inline-flex flex-wrap items-baseline gap-2">
                        <Link
                          href={project.href}
                          external
                          class="font-medium text-stone-900 hover:text-stone-600 dark:text-stone-100 dark:hover:text-stone-400"
                        >
                          {project.name}
                        </Link>
                        {project.stars && (
                          <span class="text-xs text-stone-400 dark:text-stone-500">
                            {project.stars}
                          </span>
                        )}
                        {project.homepage && (
                          <Link
                            href={project.homepage}
                            external
                            class="text-xs text-stone-400 hover:text-stone-600 dark:text-stone-500 dark:hover:text-stone-400"
                          >
                            主页
                          </Link>
                        )}
                        {project.badge && (
                          <span class="rounded bg-stone-100 px-1.5 py-0.5 text-xs leading-none text-stone-400 dark:bg-stone-800 dark:text-stone-500">
                            {project.badge}
                          </span>
                        )}
                        <span class="text-stone-400 dark:text-stone-500">
                          — {project.description}
                        </span>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
          <Link
            href="https://github.com/username?tab=repositories"
            external
            class="inline-block text-sm text-stone-500 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100"
          >
            探索更多
          </Link>
        </div>
      </section>

      <!-- 技术栈 -->
      <section class="animate">
        <h2
          class="mb-3 flex items-center gap-2 text-base font-semibold text-stone-900 sm:mb-4 sm:text-lg dark:text-stone-100"
        >
          Tech
        </h2>
        <div class="space-y-6">
          {
            TECH_STACK.map((group) => (
              <div class="space-y-2">
                <h3 class="text-xs font-medium uppercase tracking-wider text-stone-500 dark:text-stone-400">
                  {group.category}
                </h3>
                <ul class="space-y-2">
                  {group.items.map((tech) => (
                    <li class="text-sm text-stone-700 dark:text-stone-300">
                      <Link
                        href={tech.href}
                        external
                        class="font-medium text-stone-900 dark:text-stone-100"
                      >
                        {tech.name}
                      </Link>
                      <span class="text-stone-400 dark:text-stone-500">
                        {" "}— {tech.description}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </Container>
</PageLayout>
