{
  "name": "astro-doge",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "version": "1.1.0",
  "description": "A static-first Astro blog template with posts, thoughts, search, PWA, and optional Vercel-ready GitHub-powered comments and likes.",
  "license": "MIT",
  "homepage": "https://github.com/dogxii/astro-doge",
  "repository": {
    "type": "git",
    "url": "https://github.com/dogxii/astro-doge.git"
  },
  "bugs": {
    "url": "https://github.com/dogxii/astro-doge/issues"
  },
  "keywords": [
    "astro",
    "blog",
    "template",
    "theme",
    "tailwindcss",
    "mdx",
    "pwa"
  ],
  "scripts": {
    "dev": "astro dev",
    "dev:network": "astro dev --host",
    "build": "rm -rf .astro node_modules/.vite && astro check && astro build",
    "preview": "astro preview",
    "preview:network": "astro preview --host",
    "astro": "astro",
    "format": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "new:blog": "bun run scripts/new-blog.ts",
    "new:thought": "bun run scripts/new-thought.ts",
    "new": "bun run scripts/new-blog.ts",
    "t": "bun run scripts/new-thought.ts"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "5.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "astro": "^6.1.7",
    "astro-expressive-code": "^0.41.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@vercel/node": "^5.7.13",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
